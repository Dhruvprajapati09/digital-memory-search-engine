# Mistral AI (required for embeddings and chat/RAG)
MISTRAL_API_KEY=
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-small-latest

# Pinecone vector database (required)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Optional namespace within the index (leave empty for default)
PINECONE_NAMESPACE=
# Must match Mistral model output (mistral-embed = 1024; do not pass output_dimension to API)
PINECONE_EMBEDDING_DIMENSION=1024

# Topic chunking — max tokens per semantic chunk before splitting
CHUNK_MAX_TOKENS=512

# RAG retrieval tuning
RAG_TOP_K=8
RAG_MIN_SCORE=0.15
